# ===========================================
# PASS Mentoring System - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# --- Database (Neon PostgreSQL recommended) ---
# Get these from https://neon.tech → your project → Connection Details
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- NextAuth ---
# Set this to your deployed URL (e.g., https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# --- Vercel Blob (File Storage) ---
# Automatically provided on Vercel deployments via OIDC.
# For local development, get this from:
# Vercel Dashboard → your project → Storage → Blob → Settings → Tokens
BLOB_READ_WRITE_TOKEN=""

# --- Email (Resend recommended) ---
# Get from https://resend.com/api-keys
RESEND_API_KEY=""
